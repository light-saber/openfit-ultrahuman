{
  "name": "pulseboard-fitbit-desktop",
  "version": "1.0.0",
  "description": "A private, desktop-first Fitbit dashboard built with Electron.",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "author": "Pulseboard",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.8",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "check:electron": "node --check electron/main.cjs && node --check electron/preload.cjs && node --check electron/google-health-service.cjs && node --check electron/fitbit-legacy-service.cjs && node --check electron/health-cache.cjs && node --check electron/codex-service.cjs",
    "check": "npm run typecheck && npm run check:electron && npm test && npm run build",
    "capture:ui": "electron scripts/capture-ui.cjs",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.23",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "nucleo-ui-essential-fill-duo-18": "1.1.6",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "shadcn": "4.11.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "com.pulseboard.fitbit",
    "productName": "Pulseboard",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "electron/**/*.cjs",
      "build/icon.png",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "hardenedRuntime": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
